{
  "name": "onnx-addon",
  "version": "0.1.0",
  "dependencies": [
    {
      "name": "onnxruntime",
      "platform": "!(android | osx | ios | windows)"
    },
    {
      "name": "onnxruntime",
      "features": ["dml-ep"],
      "platform": "windows"
    },
    {
      "name": "onnxruntime",
      "features": ["nnapi-ep"],
      "platform": "android"
    },
    {
      "name": "onnxruntime",
      "features": ["coreml-ep"],
      "platform": "osx | ios"
    }
  ],
  "overrides": [
    {
      "name": "flatbuffers",
      "version": "23.5.26"
    }
  ]
}
