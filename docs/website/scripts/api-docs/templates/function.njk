{#- Per-function API reference page.
    Context: { fn: ApiFunction }

    The macro must be defined before it is called.
-#}
{%- macro renderExpandedTypes(types, depth) -%}
{% for expanded in types -%}
{%- set clampedDepth = depth if depth <= 5 else 5 -%}
{%- set hashes = "#" * clampedDepth %}

{{ hashes }} `{{ expanded.typeName }}`

| Field | Type | Required? | Description |
| --- | --- | :---: | --- |
{% for f in expanded.fields -%}
| `{{ f.name }}` | `{{ f.type | escapeTable }}` | {{ "✓" if f.required else "✗" }} | {{ (f.description or "—") | escapeTable }} |
{% endfor -%}
{% if expanded.children.length > 0 -%}
{{ renderExpandedTypes(expanded.children, depth + 1) }}
{%- endif -%}
{%- endfor -%}
{%- endmacro -%}

{%- set desc = (fn.description or "No description available") | replace('"', '\\"') | replace('undefined', '—') -%}
